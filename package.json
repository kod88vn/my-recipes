{
  "name": "ai-skill-library",
  "version": "0.1.0",
  "private": true,
  "description": "Manage and share VS Code Copilot agent SKILL.md files across projects",
  "type": "module",
  "files": [
    "skills",
    "bin",
    "lib",
    "scripts"
  ],
  "bin": {
    "skill-lib": "bin/skill-lib.js",
    "create-turborepo": "bin/create-turborepo.js"
  },
  "scripts": {
    "postinstall": "node scripts/install.js",
    "serve": "node bin/skill-lib.js serve",
    "ui": "streamlit run ui/app.py",
    "dev": "node -e \"require('child_process').spawn('node',['bin/skill-lib.js','serve'],{stdio:'inherit',shell:true}); require('child_process').spawn('streamlit',['run','ui/app.py'],{stdio:'inherit',shell:true})\""
  },
  "dependencies": {
    "commander": "^13.1.0"
  }
}
